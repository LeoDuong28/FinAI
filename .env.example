# FinAI Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ─── Server ───────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=development  # development | production

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgres://finai:localdev@localhost:5432/finai?sslmode=disable

# ─── Security ─────────────────────────────────────────
# JWT secret: minimum 32 characters
JWT_SECRET=change-me-to-a-random-32-char-string!!
# AES-256 encryption key: exactly 32 bytes
ENCRYPTION_KEY=change-me-to-exactly-32-bytes!!

# ─── Plaid (Sandbox) ─────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ─── AI Service ───────────────────────────────────────
AI_SERVICE_URL=http://localhost:8081
AI_SERVICE_KEY=change-me-to-a-random-service-key
AI_HMAC_SECRET=change-me-to-a-random-hmac-secret

# ─── Google Gemini ────────────────────────────────────
GEMINI_API_KEY=

# ─── Email (Resend.com) ──────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@finai.app

# ─── Feature Flags ────────────────────────────────────
FF_AI_CHAT=true
FF_BILL_NEGOTIATION=true
FF_PWA=true
FF_WEEKLY_SUMMARY=true
FF_CREDIT_SCORE=false
DEMO_MODE=false
